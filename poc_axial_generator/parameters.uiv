[version]
format: 0.1.0
unit_frame: si_metric.ut

[notes]
# The configuration file describes a 3-phase axial generator simulation
# It is simulated via magneto loop in axial-symmetric coordinate system (Z-R) (Axial-Radial)

[model]
energy_required: 1 (J)

environmental_material: "air"
number_pairs: 8
number_slots: 24

cycling_efficiency: 0.6
shaking_frequency: 4 (s^-1)

[armature_core]
gap_radial_thickness: 0.5 m(m)
wall_radial_thickness: 1 m(m)

[armature_slots]
material: "copper"
wire_diameter: 0.2 m(m)
fill_factor: 0.70

axial_length: 2 m(m)
radial_thickness: 2 m(m)

[stator_poles]
material: "NdFeB"
grade: "N52"

radial_thickness: 5 m(m)
axial_length: 10 m(m)